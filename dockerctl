#!/usr/bin/env bash
set -e

DOCKER_SERVICE="docker.service"
DOCKER_SOCKET="docker.socket"

usage() {
echo "Usage: $0 {start|stop|status}"
exit 1
}

[ $# -eq 1 ] || usage

case "$1" in
start)
echo "Enabling manual Docker access..."
sudo systemctl unmask "$DOCKER_SERVICE" "$DOCKER_SOCKET"
sudo systemctl start "$DOCKER_SOCKET"
sudo systemctl start "$DOCKER_SERVICE"
echo
systemctl status "$DOCKER_SERVICE" --no-pager || true
;;
stop)
echo "Stopping and strictly locking Docker..."
sudo systemctl stop "$DOCKER_SERVICE" 2>/dev/null || true
sudo systemctl stop "$DOCKER_SOCKET" 2>/dev/null || true
sudo systemctl disable "$DOCKER_SERVICE" "$DOCKER_SOCKET" 2>/dev/null || true
sudo systemctl mask "$DOCKER_SERVICE" "$DOCKER_SOCKET"
echo
echo "Docker is now stopped and masked."
;;
status)
echo "=== docker.service ==="
systemctl status "$DOCKER_SERVICE" --no-pager || true
echo
echo "=== docker.socket ==="
systemctl status "$DOCKER_SOCKET" --no-pager || true
echo
echo "=== enable state ==="
systemctl is-enabled "$DOCKER_SERVICE" || true
systemctl is-enabled "$DOCKER_SOCKET" || true
;;
*)
usage
;;
esac
